{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "outputs/tsc/dist",
    "tsBuildInfoFile": "outputs/tsc/src.tsbuildinfo",
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/GlobalSetup.ts", 
    "src/Sandbox.ts",
    "src/StartContainers.ts",
    "src/**/*.node.unit.test.ts",
    "src/**/*.node.integration.test.ts",
    "src/**/*.test-d.ts"
  ]
}
